{
  "name": "study-go-with-zeenat",
  "version": "1.0.0",
  "description": "Judiciary and LLB preparation platform",
  "main": "server/index.js",
  "scripts": {
    "build": "npm install --prefix server --production=false && npm install --prefix client --production=false && npm run build --prefix client",
    "start": "node server/index.js",
    "server": "npm start --prefix server",
    "client": "npm run dev --prefix client",
    "dev": "concurrently \"npm run server\" \"npm run client\""
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "concurrently": "^8.2.2"
  }
}
